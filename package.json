{
  "name": "newsbot",
  "private": true,
  "workspaces": [
    "admin",
    "api"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names admin,api \"npm:dev:admin\" \"npm:dev:api\"",
    "dev:admin": "npm run dev -w newsbot-admin",
    "dev:api": "npm run dev -w newsbot-api -- --inspector-port 9229",
    "build": "npm run build:admin && node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});fs.cpSync('admin/dist','dist',{recursive:true});\"",
    "build:admin": "npm run build -w newsbot-admin",
    "deploy:api": "npm run deploy -w newsbot-api",
    "lint": "npm run lint -w newsbot-admin && npm run lint -w newsbot-api",
    "format": "npm run format -w newsbot-admin && npm run format -w newsbot-api",
    "check:schedules": "node scripts/check-schedule-sync.mjs"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
